<main class="inspection-container">
  <p class="inspection-context">
    Proteins loaded into the experiment. Each protein's variants are evaluated by a
    rule-based structural lookup engine and compared against MaveDB functional scores
    and ClinVar clinical classifications.
  </p>

  <header class="inspection-page-header">
    <h1>Proteins</h1>
    <p>
      <%= link_to "Back to Home", root_path, class: "inspection-link" %>
    </p>
  </header>

  <section class="inspection-grid">
    <% @proteins.each do |protein| %>
      <%= render "protein_card", protein: protein %>
    <% end %>
  </section>
</main>
