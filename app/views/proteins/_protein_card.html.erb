<%= render layout: "shared/card",
           locals: {
             title: protein.uniprot_accession,
             header_action: link_to("Open Protein", protein_path(protein), class: "inspection-link")
           } do %>
  <dl class="inspection-kv">
    <dt>Gene</dt>
    <dd><%= protein.gene_symbol.presence || "-" %></dd>
    <dt>Name</dt>
    <dd><%= protein.recommended_name.presence || "-" %></dd>
    <dt>Organism</dt>
    <dd><%= protein.organism.presence || "-" %></dd>
  </dl>

  <div class="inspection-counts">
    <span>Variants <strong><%= protein.variants.size %></strong></span>
    <span>Features <strong><%= protein.protein_features.size %></strong></span>
    <span>Structures <strong><%= protein.structure_entries.size %></strong></span>
  </div>
<% end %>
