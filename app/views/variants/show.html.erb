<main class="inspection-container">
  <p class="inspection-context">
    Rule-based lookup result for
    <strong><%= @variant.hgvs_protein %></strong>
    — does this residue position fall in a known functional domain and resolved
    structure, and does that finding agree with peer-reviewed evidence?
  </p>

  <header class="inspection-page-header">
    <h1>Variant <%= @variant.hgvs_protein %></h1>
    <p>
      <%= link_to "Back to Protein", protein_path(@variant.protein), class: "inspection-link" %>
    </p>
  </header>

  <section class="inspection-stack">
    <%= render layout: "shared/card", locals: { title: "Evidence Agreement" } do %>
      <p class="inspection-finding">
        <% if @evidence[:overall_agreement] == :agree %>
          System output is <strong>consistent</strong> with peer-reviewed experimental
          evidence (MaveDB + ClinVar).
        <% elsif @evidence[:overall_agreement] == :disagree %>
          System output <strong>disagrees</strong> with one or more peer-reviewed
          evidence sources.
        <% else %>
          Insufficient peer-reviewed evidence to assess agreement.
        <% end %>
      </p>

      <dl class="inspection-kv">
        <dt>System mechanism</dt>
        <dd><%= @evidence[:system_mechanism] %></dd>
        <dt>Structural score</dt>
        <dd><%= @evidence[:structural_confidence_score].to_i %> / 60</dd>
        <dt>Evidence score</dt>
        <dd><%= @evidence[:evidence_confidence_score].to_i %> / 40</dd>
        <dt>Combined confidence</dt>
        <dd class="confidence-badge confidence-<%= @evidence[:confidence_level] %>">
          <%= @evidence[:confidence_level].to_s.upcase %>
        </dd>
        <dt>MaveDB agreement</dt>
        <dd class="agreement-<%= @evidence.dig(:mavedb, :agreement) %>">
          <%= @evidence.dig(:mavedb, :agreement) %> — <%= @evidence.dig(:mavedb, :note) %>
        </dd>
        <dt>ClinVar agreement</dt>
        <dd class="agreement-<%= @evidence.dig(:clinvar, :agreement) %>">
          <%= @evidence.dig(:clinvar, :agreement) %> — <%= @evidence.dig(:clinvar, :note) %>
        </dd>
        <dt>Overall</dt>
        <dd class="agreement-<%= @evidence[:overall_agreement] %> agreement-overall">
          <%= @evidence[:overall_agreement].to_s.upcase %>
        </dd>
      </dl>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Variant Summary" } do %>
      <dl class="inspection-kv">
        <dt>Protein</dt>
        <dd><%= @variant.protein.uniprot_accession %></dd>
        <dt>HGVS</dt>
        <dd><%= @variant.hgvs_protein %></dd>
        <dt>Residue Position</dt>
        <dd><%= @variant.residue_position %></dd>
        <dt>Amino Acid Change</dt>
        <dd><%= @variant.ref_aa %>→<%= @variant.alt_aa %></dd>
      </dl>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Interpretation" } do %>
      <dl class="inspection-kv">
        <dt>Preliminary Mechanism</dt>
        <dd><%= @interpretation[:preliminary_mechanism] %></dd>
        <dt>Confidence</dt>
        <dd><%= @interpretation[:confidence] %></dd>
        <dt>Domain Hit</dt>
        <dd><%= @interpretation[:domain_hit] %></dd>
        <dt>Structure Hit</dt>
        <dd><%= @interpretation[:structure_hit] %></dd>
      </dl>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Matching Features" } do %>
      <% if @interpretation[:matching_features].any? %>
        <table class="inspection-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Start</th>
              <th>End</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% @interpretation[:matching_features].each do |feature| %>
              <tr>
                <td><%= feature[:feature_type] %></td>
                <td><%= feature[:start_pos] %></td>
                <td><%= feature[:end_pos] %></td>
                <td><%= feature[:description].presence || "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="inspection-empty">No matching features.</p>
      <% end %>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Matching Structures" } do %>
      <% if @interpretation[:matching_structures].any? %>
        <table class="inspection-table">
          <thead>
            <tr>
              <th>PDB</th>
              <th>Chain</th>
              <th>Start</th>
              <th>End</th>
              <th>Method</th>
            </tr>
          </thead>
          <tbody>
            <% @interpretation[:matching_structures].each do |entry| %>
              <tr>
                <td><%= entry[:pdb_id] %></td>
                <td><%= entry[:chain_id].presence || "-" %></td>
                <td><%= entry[:start_pos] %></td>
                <td><%= entry[:end_pos] %></td>
                <td><%= entry[:method] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="inspection-empty">No matching structures.</p>
      <% end %>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "MaveDB Functional Score" } do %>
      <% mavedb = @variant.mavedb_score %>
      <% if mavedb %>
        <dl class="inspection-kv">
          <dt>Score</dt>
          <dd><%= "%.4f" % mavedb.score %></dd>
          <dt>Source</dt>
          <dd><%= mavedb.source %></dd>
          <dt>Score Set</dt>
          <dd><%= mavedb.score_set_urn %></dd>
        </dl>
      <% else %>
        <p class="inspection-empty">No MaveDB score found for <%= @variant.hgvs_protein %>.</p>
      <% end %>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "ClinVar Classification" } do %>
      <% clinvar = @variant.clinvar_classification %>
      <% if clinvar %>
        <dl class="inspection-kv">
          <dt>Classification</dt>
          <dd><%= clinvar.clinical_significance %></dd>
          <dt>Review Status</dt>
          <dd><%= clinvar.review_status %></dd>
          <dt>Last Evaluated</dt>
          <dd><%= clinvar.last_evaluated.presence || "-" %></dd>
          <dt>Variation ID</dt>
          <dd><%= clinvar.variation_id %></dd>
        </dl>
      <% else %>
        <p class="inspection-empty">No ClinVar classification found for <%= @variant.hgvs_protein %>.</p>
      <% end %>
    <% end %>

  </section>
</main>
