<main class="inspection-container">
  <section class="inspection-stack">

    <%= render layout: "shared/card", locals: { title: "Research Goal" } do %>
      <p class="inspection-lead">
        Can a deterministic system built primarily with LLMs produce scientifically valid
        results when compared to peer-reviewed experimental data?
      </p>
      <p>
        This application processes public protein variant data using a blackboard
        architecture with four knowledge sources: DomainMapper, StructureMapper,
        Interpretation, and EvidenceValidator. Phase 1-3 validated the system against
        TP53 (UniProt P04637) using MaveDB functional scores and ClinVar germline
        classifications. Phase 4 extended the architecture to tau (P10636) and
        APP/amyloid-beta (P05067) to provide structural context for the competitive
        microtubule binding hypothesis (Julian et al. 2026).
      </p>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Phase 1-3: TP53 Benchmark Results" } do %>
      <table class="inspection-table">
        <thead>
          <tr>
            <th>Variant</th>
            <th>MaveDB score</th>
            <th>ClinVar</th>
            <th>System confidence</th>
            <th>Agreement</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>p.Arg175His</td><td>1.025</td><td>Pathogenic (expert panel)</td><td>High</td><td>Agree</td></tr>
          <tr><td>p.Gly245Ser</td><td>0.772</td><td>Pathogenic</td><td>High</td><td>Agree</td></tr>
          <tr><td>p.Arg248Gln</td><td>0.812</td><td>Pathogenic</td><td>High</td><td>Agree</td></tr>
          <tr><td>p.Arg273His</td><td>1.221</td><td>Pathogenic (expert panel)</td><td>High</td><td>Agree</td></tr>
          <tr><td>p.Tyr220Cys</td><td>1.102</td><td>Likely pathogenic (expert panel)</td><td>High</td><td>Agree</td></tr>
        </tbody>
      </table>
      <p style="margin-top: 0.75rem;">
        Overall agreement rate: <strong>100% (5/5 variants)</strong> across MaveDB and ClinVar.
      </p>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Phase 4: Tau and APP/Amyloid-Beta (Julian et al. 2026)" } do %>
      <p>
        Extension to the competitive microtubule binding hypothesis. No MaveDB or ClinVar
        evidence available; structural axis only. Negative controls (R406W, Swedish, London)
        confirm the system discriminates variants outside the binding region.
      </p>
      <table class="inspection-table">
        <thead>
          <tr>
            <th>Protein</th>
            <th>Variant</th>
            <th>Literature name</th>
            <th>Domain hit</th>
            <th>Structure hit</th>
            <th>Str. score</th>
          </tr>
        </thead>
        <tbody>
          <tr><td>MAPT</td><td>p.Pro619Leu</td><td>P301L</td><td>Yes</td><td>Yes</td><td>50</td></tr>
          <tr><td>MAPT</td><td>p.Pro619Ser</td><td>P301S</td><td>Yes</td><td>Yes</td><td>50</td></tr>
          <tr><td>MAPT</td><td>p.Arg724Trp</td><td>R406W</td><td>No</td><td>No</td><td>0</td></tr>
          <tr><td>APP</td><td>p.Ala692Gly</td><td>Arctic</td><td>Yes</td><td>Yes</td><td>50</td></tr>
          <tr><td>APP</td><td>p.Lys670Asn</td><td>Swedish</td><td>No</td><td>No</td><td>0</td></tr>
          <tr><td>APP</td><td>p.Val717Ile</td><td>London</td><td>No</td><td>No</td><td>0</td></tr>
        </tbody>
      </table>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Architecture" } do %>
      <p>
        Four knowledge sources over five SQLite databases. Scoring combines a structural
        axis (0–60: domain hit, PDB structure hit, resolution bonus) and an evidence axis
        (0–40: MaveDB score magnitude, ClinVar review quality). Combined total ≥ 70 → high,
        ≥ 40 → moderate, else low.
      </p>
      <p>
        Two-stage LLM workflow: Claude (architect, scientist, prompt author) +
        Codex CLI (implementer). Failure modes documented in CLAUDE_ERRORS.md.
      </p>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Inspect" } do %>
      <p>
        <%= link_to "Browse Proteins", proteins_path, class: "inspection-link" %>
      </p>
    <% end %>

    <%= render layout: "shared/card", locals: { title: "Utilities" } do %>
      <p class="inspection-lead">Run built-in local fixture import tasks.</p>
      <%= button_to "Import TP53 Fixture", import_tp53_fixture_path, method: :post, class: "inspection-button" %>
      <p style="margin-top: 0.5rem; font-size: 0.85rem;">
        Tau and APP fixtures: <code>bin/rails protein_variants:import_tau</code> /
        <code>bin/rails protein_variants:import_app</code>
      </p>
    <% end %>

  </section>
</main>
