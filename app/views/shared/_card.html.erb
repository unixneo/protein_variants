<article class="inspection-card">
  <% if local_assigns[:title].present? %>
    <header class="inspection-card__header inspection-card__header--flex">
      <h2 class="inspection-card__title"><%= title %></h2>
      <% if local_assigns[:header_action].present? %>
        <div class="inspection-card__header-action"><%= header_action %></div>
      <% end %>
    </header>
  <% end %>
  <div class="inspection-card__body">
    <%= yield %>
  </div>
</article>
